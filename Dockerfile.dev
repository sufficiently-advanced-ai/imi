# Development Dockerfile - Combined FastAPI + Next.js container with demo auth
FROM nikolaik/python-nodejs:python3.11-nodejs20

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    nginx \
    supervisor \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy Python requirements and install
COPY requirements.txt .
COPY deployment/strip-unused-ml-deps.sh /tmp/strip-unused-ml-deps.sh
# Strip is chained into the same RUN as the install so the removed bytes don't
# persist in a lower layer (Docker layers are additive). See the script header.
RUN pip install --no-cache-dir -r requirements.txt \
 && bash /tmp/strip-unused-ml-deps.sh
RUN pip install --no-cache-dir python-multipart==0.0.6

# Install Claude Agent SDK CLI for claude-agent-sdk Python package
# Dev container will use host's subscription credentials via volume mount
RUN npm install -g @anthropic-ai/claude-code @anthropic-ai/claude-agent-sdk

# Copy Node.js package files
COPY imi-frontend/package*.json ./imi-frontend/

# Install Node dependencies
WORKDIR /app/imi-frontend
RUN npm ci --legacy-peer-deps

# Copy application code
WORKDIR /app
COPY app/ app/
COPY imi-frontend/ imi-frontend/
COPY config/ config/
COPY tests/ tests/
COPY scripts/ scripts/
COPY evals/ evals/
COPY alembic.ini alembic.ini
COPY migrations/ migrations/
COPY .env.test .env.test

# Build Next.js application
WORKDIR /app/imi-frontend

# Build arguments for Next.js - DEV SPECIFIC with demo mode
# No basePath for dev builds - runs at root
ARG NEXT_PUBLIC_API_URL=/api
ARG NEXT_PUBLIC_AUTH_MODE=demo


# Set build-time environment variables
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_AUTH_MODE=${NEXT_PUBLIC_AUTH_MODE}
# No basePath for dev builds
ENV NEXT_PUBLIC_BASE_PATH=""
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

# Only set Next.js-specific ones that are needed for build

# Backend URL for server-side API calls (without /api suffix, frontend adds it)
ENV BACKEND_URL=http://localhost:8000

# Build Next.js without basePath for dev (runs at root)
RUN echo "Building Next.js for development (no basePath)" && \
    npm run build

# Copy dev configurations (dev-specific nginx config)
WORKDIR /app
COPY deployment/nginx.dev.conf /etc/nginx/nginx.conf
COPY deployment/supervisord.conf /etc/supervisor/conf.d/supervisord.conf
COPY deployment/entrypoint.sh /app/entrypoint.sh

# Create necessary directories
RUN mkdir -p /app/repo /var/log/supervisor

# Set proper permissions
RUN chmod +x /app/entrypoint.sh

# Environment setup
ENV PYTHONUNBUFFERED=1
# Keep production for runtime to match the build
ENV NODE_ENV=production
ENV ENV_FILE=.env.test
ENV DOMAIN_CONFIG_DIR=/app/config/domains

# Expose only the nginx port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD curl -f http://localhost:8080/health || exit 1

# Start services via entrypoint
ENTRYPOINT ["/app/entrypoint.sh"]