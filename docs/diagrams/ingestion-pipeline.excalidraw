  "appState": { "viewBackgroundColor": "#ffffff" },
  "elements": [
    { "id": "title", "type": "text", "x": 0, "y": -60, "width": 1060, "text": "Ingestion pipeline — IngestOrchestrator phases", "fontSize": 22, "fontWeight": "bold", "textAlign": "center", "strokeColor": "#1e1e1e" },

    { "id": "intake", "type": "rectangle", "x": 0, "y": 20, "width": 170, "height": 70, "strokeColor": "#1e1e1e", "backgroundColor": "#f1f3f5", "roundness": {"type": 3}, "boundElements": [{"id": "intakeT", "type": "text"}] },
    { "id": "intakeT", "type": "text", "containerId": "intake", "x": 10, "y": 35, "text": "POST /api/ingest\n(202 + job_id)", "fontSize": 13 },

    { "id": "p1", "type": "rectangle", "x": 230, "y": 20, "width": 170, "height": 70, "strokeColor": "#1971c2", "backgroundColor": "#d0ebff", "roundness": {"type": 3}, "boundElements": [{"id": "p1T", "type": "text"}] },
    { "id": "p1T", "type": "text", "containerId": "p1", "x": 240, "y": 35, "text": "1 CLASSIFY\ncontent type", "fontSize": 13 },
    { "id": "p2", "type": "rectangle", "x": 460, "y": 20, "width": 170, "height": 70, "strokeColor": "#1971c2", "backgroundColor": "#d0ebff", "roundness": {"type": 3}, "boundElements": [{"id": "p2T", "type": "text"}] },
    { "id": "p2T", "type": "text", "containerId": "p2", "x": 470, "y": 35, "text": "2 BUILD\nobservation + NER", "fontSize": 13 },
    { "id": "p3", "type": "rectangle", "x": 690, "y": 20, "width": 170, "height": 70, "strokeColor": "#1971c2", "backgroundColor": "#d0ebff", "roundness": {"type": 3}, "boundElements": [{"id": "p3T", "type": "text"}] },
    { "id": "p3T", "type": "text", "containerId": "p3", "x": 700, "y": 35, "text": "3 EXTRACT\nsalient entities", "fontSize": 13 },
    { "id": "p4", "type": "rectangle", "x": 920, "y": 20, "width": 170, "height": 70, "strokeColor": "#1971c2", "backgroundColor": "#d0ebff", "roundness": {"type": 3}, "boundElements": [{"id": "p4T", "type": "text"}] },
    { "id": "p4T", "type": "text", "containerId": "p4", "x": 930, "y": 35, "text": "4 PROMOTE\nsignals", "fontSize": 13 },

    { "id": "p5", "type": "rectangle", "x": 920, "y": 190, "width": 170, "height": 70, "strokeColor": "#1971c2", "backgroundColor": "#d0ebff", "roundness": {"type": 3}, "boundElements": [{"id": "p5T", "type": "text"}] },
    { "id": "p5T", "type": "text", "containerId": "p5", "x": 930, "y": 205, "text": "5-6 SUPERSESSION\n& CONFLICTS", "fontSize": 13 },
    { "id": "p6", "type": "rectangle", "x": 690, "y": 190, "width": 170, "height": 70, "strokeColor": "#2f9e44", "backgroundColor": "#d3f9d8", "roundness": {"type": 3}, "boundElements": [{"id": "p6T", "type": "text"}] },
    { "id": "p6T", "type": "text", "containerId": "p6", "x": 700, "y": 205, "text": "7 ENRICH_GRAPH\nnodes + edges", "fontSize": 13 },
    { "id": "p7", "type": "rectangle", "x": 460, "y": 190, "width": 170, "height": 70, "strokeColor": "#2f9e44", "backgroundColor": "#d3f9d8", "roundness": {"type": 3}, "boundElements": [{"id": "p7T", "type": "text"}] },
    { "id": "p7T", "type": "text", "containerId": "p7", "x": 470, "y": 205, "text": "8 PERSIST\ngit commit", "fontSize": 13 },
    { "id": "p8", "type": "rectangle", "x": 230, "y": 190, "width": 170, "height": 70, "strokeColor": "#2f9e44", "backgroundColor": "#d3f9d8", "roundness": {"type": 3}, "boundElements": [{"id": "p8T", "type": "text"}] },
    { "id": "p8T", "type": "text", "containerId": "p8", "x": 240, "y": 205, "text": "9 ENRICH_PROFILES\ngrounded profiles", "fontSize": 13 },
    { "id": "p9", "type": "rectangle", "x": 0, "y": 190, "width": 170, "height": 70, "strokeColor": "#2f9e44", "backgroundColor": "#d3f9d8", "roundness": {"type": 3}, "boundElements": [{"id": "p9T", "type": "text"}] },
    { "id": "p9T", "type": "text", "containerId": "p9", "x": 10, "y": 205, "text": "10 DELTA_REPORT\nwhat changed", "fontSize": 13 },

