    { "id": "llmT", "type": "text", "containerId": "llm", "x": 390, "y": 112, "text": "Claude (Haiku) · prompts in app/prompts/*.xml\nphases 1, 3, 4, 6, and edge inference in 7", "fontSize": 12 },

    { "id": "storeGraph", "type": "rectangle", "x": 630, "y": 330, "width": 290, "height": 60, "strokeColor": "#868e96", "backgroundColor": "#f1f3f5", "roundness": {"type": 3}, "boundElements": [{"id": "storeGraphT", "type": "text"}] },
    { "id": "storeGraphT", "type": "text", "containerId": "storeGraph", "x": 640, "y": 345, "text": "Neo4j: (:Entity), (:Signal), edges\n+ signal store & vector index", "fontSize": 12 },
    { "id": "storeGit", "type": "rectangle", "x": 260, "y": 330, "width": 290, "height": 60, "strokeColor": "#868e96", "backgroundColor": "#f1f3f5", "roundness": {"type": 3}, "boundElements": [{"id": "storeGitT", "type": "text"}] },
