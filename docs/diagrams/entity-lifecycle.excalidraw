  "elements": [
    { "id": "title", "type": "text", "x": 0, "y": -60, "width": 1000, "text": "Entity lifecycle — extraction, resolution, write-through", "fontSize": 22, "fontWeight": "bold", "textAlign": "center", "strokeColor": "#1e1e1e" },

    { "id": "surface", "type": "rectangle", "x": 0, "y": 60, "width": 200, "height": 90, "strokeColor": "#1e1e1e", "backgroundColor": "#f1f3f5", "roundness": {"type": 3}, "boundElements": [{"id": "surfaceT", "type": "text"}] },
    { "id": "surfaceT", "type": "text", "containerId": "surface", "x": 10, "y": 80, "text": "surface forms\n\"Jordan\", \"Acme\",\n\"ACME Corp.\"", "fontSize": 13 },

    { "id": "resolver", "type": "rectangle", "x": 280, "y": 20, "width": 280, "height": 190, "strokeColor": "#1971c2", "backgroundColor": "#d0ebff", "roundness": {"type": 3}, "boundElements": [{"id": "resolverT", "type": "text"}] },
    { "id": "resolverT", "type": "text", "containerId": "resolver", "x": 290, "y": 40, "text": "EntityResolver\n(entity_resolver.py, pure)\n\n1. exact  — slug match\n2. alias  — normalized form\n3. fuzzy  — per-type threshold\n4. new    — mint a slug", "fontSize": 13 },

    { "id": "ner", "type": "rectangle", "x": 0, "y": 190, "width": 200, "height": 78, "strokeColor": "#e8590c", "backgroundColor": "#ffe8cc", "roundness": {"type": 3}, "boundElements": [{"id": "nerT", "type": "text"}] },
    { "id": "nerT", "type": "text", "containerId": "ner", "x": 10, "y": 205, "text": "NER + LLM extraction\nsteered by ner_labels /\nner_exclude", "fontSize": 12 },

    { "id": "schema", "type": "rectangle", "x": 300, "y": 280, "width": 240, "height": 64, "strokeColor": "#7048e8", "backgroundColor": "#e5dbff", "roundness": {"type": 3}, "boundElements": [{"id": "schemaT", "type": "text"}] },
    { "id": "schemaT", "type": "text", "containerId": "schema", "x": 310, "y": 295, "text": "domain schema validates\nentity & relationship types", "fontSize": 13 },

    { "id": "write", "type": "rectangle", "x": 650, "y": 60, "width": 240, "height": 110, "strokeColor": "#2f9e44", "backgroundColor": "#d3f9d8", "roundness": {"type": 3}, "boundElements": [{"id": "writeT", "type": "text"}] },
    { "id": "writeT", "type": "text", "containerId": "write", "x": 660, "y": 85, "text": "graph write\nMERGE (:Entity:Type {id})\n+ relationship edges", "fontSize": 13 },

