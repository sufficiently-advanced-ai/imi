    { "id": "md", "type": "rectangle", "x": 800, "y": 240, "width": 190, "height": 84, "strokeColor": "#868e96", "backgroundColor": "#f1f3f5", "roundness": {"type": 3}, "boundElements": [{"id": "mdT", "type": "text"}] },
