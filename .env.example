# imi — environment configuration
# Copy this to .env and fill in the required values.

# ── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Neo4j password — must match NEO4J_AUTH in docker-compose.yml
NEO4J_PASSWORD=your-neo4j-password

# ── Optional: git corpus ──────────────────────────────────────────────────────
# Connect a git repo as the knowledge corpus.
# Omit to use file-upload-only mode.
# Setup guide (repo creation, token scopes, webhook): docs/getting-started/git-corpus.md
# WARNING: once GIT_REPO_URL is set, the remote is authoritative — the local
# ./repo is wiped and re-cloned at startup. Push an existing local corpus first.
# GIT_REPO_URL=https://github.com/your-org/your-kb-repo.git
# GITHUB_ACCESS_TOKEN=your-github-personal-access-token
# GIT_BRANCH=main

# ── App mode ─────────────────────────────────────────────────────────────────
AUTH_MODE=none         # none | demo

# ── Neo4j (defaults match docker-compose.yml) ─────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j

# ── Vector store ─────────────────────────────────────────────────────────────
# Backend for the governed-memory semantic index (signals, captured thoughts,
# agent memories). The default persists vectors in a SQLite sidecar file
# (vectors.db, beside the app database) and survives restarts.
#   sqlite   — default; no extra services
#   pgvector — Postgres + pgvector (hosted deployments; needs DATABASE_URL)
#   faiss    — legacy in-memory path; not recommended (loses vectors on
#              restart, and semantic recall returns no results — the bundled
#              semantica FAISS facade drops vector metadata)
# After switching backends or cloning an existing corpus, rebuild the index:
#   curl -X POST localhost:8080/api/admin/backfill-memory-index
# VECTOR_BACKEND=sqlite

# ── Domain ───────────────────────────────────────────────────────────────────
# Pick from config/domains/: consulting_firm, b2b_saas, agency,
# solo_consulting, member_network, personal_crm
ACTIVE_DOMAIN=consulting_firm

# ── AI models ────────────────────────────────────────────────────────────────
# Defaults are current Claude models. Override only if needed.
# CLAUDE_SONNET_MODEL=claude-sonnet-4-5-20250929
# CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# ── Port ─────────────────────────────────────────────────────────────────────
PORT=8080

# ── Optional observability ───────────────────────────────────────────────────
# The app can export OTLP telemetry (traces + metrics) to an observability
# stack you already run. Point this at your collector's OTLP/HTTP endpoint —
# port 4318 (4317 is gRPC, unsupported). Left unset, the exporter is disabled
# and the app runs without telemetry.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# To switch off app-side telemetry entirely:
# OTEL_ENABLED=false
# Label attached to LLM/document/entity metrics, for dashboard filtering:
# CLIENT_NAME=imi-dev
